PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/travelhub
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
CLIENT_URL=http://localhost:5173

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=TravelHub <noreply@travelhub.com>

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Bootstrap / deploy initialization
BOOTSTRAP_ADMIN_SECRET=your_bootstrap_secret
BOOTSTRAP_ADMIN_EMAIL=admin@travelhub.com
BOOTSTRAP_ADMIN_PASSWORD=admin123
BOOTSTRAP_ADMIN_NAME=Admin User
BOOTSTRAP_ADMIN_PHONE=+10000000000
